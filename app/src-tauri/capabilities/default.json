{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "tor",
          "sidecar": true
        },
        {
          "name": "ipfs",
          "sidecar": true
        }
      ]
    }
  ]
}